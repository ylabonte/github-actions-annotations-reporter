{
  "name": "github-actions-annotations-reporter",
  "version": "1.0.0",
  "description": "Scans the latest GitHub Actions workflow runs for annotations and files dedup-aware GitHub Issues, with severity filters, won't-fix history-aware suppression, and auto-close when annotations vanish.",
  "keywords": [
    "github-actions",
    "annotations",
    "workflow",
    "issues",
    "cli",
    "reporter",
    "check-runs",
    "wont-fix"
  ],
  "license": "MIT",
  "author": "Yannic Labonte",
  "homepage": "https://ylabonte.github.io/github-actions-annotations-reporter/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ylabonte/github-actions-annotations-reporter.git"
  },
  "bugs": {
    "url": "https://github.com/ylabonte/github-actions-annotations-reporter/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "ghaar": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation tsx src/cli.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm run docs:gen-cli && vitepress build docs",
    "docs:gen-cli": "cross-env NODE_OPTIONS=--no-deprecation tsx docs/scripts/gen-cli-ref.ts",
    "prepublishOnly": "pnpm run build",
    "release": "changeset publish"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@commander-js/extra-typings": "^14.0.0",
    "@octokit/rest": "^22.0.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.1.2"
}
